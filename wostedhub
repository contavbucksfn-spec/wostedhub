local function CreateGradient(parent)
    local g = Instance.new("UIGradient", parent)
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(180, 200, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(18, 20, 28)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB(180, 200, 255))
    }
    g.Rotation = 0
    table.insert(_G._animatedGradients, g)
    return g
end

local function AddAnimatedStroke(stroke, thickness)
    stroke.Thickness = thickness or 1.5
    stroke.Transparency = 0
    table.insert(_G._animatedStrokes, stroke)
    CreateGradient(stroke)
    -- Registrar para o brilho BW animado
    if _G.AddBWGlow then _G.AddBWGlow(stroke)
    else
        _G._bwStrokes = _G._bwStrokes or {}
        table.insert(_G._bwStrokes, stroke)
    end
end

