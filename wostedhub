    kbLabelMv.Text = "Press a key\n[Backspace to clear]"
    kbLabelMv.Font = Enum.Font.GothamBold; kbLabelMv.TextSize = 14*SCALE
    kbLabelMv.TextColor3 = Color3.fromRGB(255,255,255)
    kbLabelMv.TextScaled = true; kbLabelMv.ZIndex = 501

    local listeningMv = false
    local function listenForFloatKey(targetBtn)
        if listeningMv then return end
        listeningMv = true
        kbPopupMv.Visible = true
        -- Don't change button text while listening; popup handles UX
        local con; con = UserInputService.InputBegan:Connect(function(inp)
            if not listeningMv then return end
            if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
            con:Disconnect(); listeningMv = false; kbPopupMv.Visible = false
            if inp.KeyCode == Enum.KeyCode.Backspace then
                Config.FloatKey = ""
                ShowNotification("FLOAT KEYBIND", "Cleared")
            else
                Config.FloatKey = inp.KeyCode.Name
                ShowNotification("FLOAT KEYBIND", inp.KeyCode.Name)
            end
            SaveConfig()
            -- Update button text and color immediately
            local newText = getFloatBtnText()
            targetBtn.Text = newText
            -- Also sync ON/OFF color (floatOn may have changed)
            targetBtn.BackgroundColor3 = floatOn and Theme.Accent1 or Theme.Surface
            targetBtn.TextColor3 = floatOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        end)
    end

    local function createMvBtn(name, defaultState, cb)
        local btnFrame = Instance.new("Frame", mvList)
        btnFrame.Size = UDim2.new(1,-16*SCALE,0,BTN_H)
        btnFrame.BackgroundTransparency = 1
        local btn = Instance.new("TextButton", btnFrame)
        btn.Size = UDim2.new(1,0,1,0)
        btn.BackgroundColor3 = defaultState and Theme.Accent1 or Theme.Surface
        btn.BackgroundTransparency = 0.1
        btn.Text = name .. (defaultState and " (ON)" or " (OFF)")
        btn.Font = Enum.Font.GothamBold; btn.TextSize = 12*SCALE
        btn.TextColor3 = defaultState and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        btn.AutoButtonColor = false
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
        local s = Instance.new("UIStroke", btn)
        s.Color = Theme.Accent2; s.Thickness = 1; s.Transparency = 0.5
        btn.MouseEnter:Connect(function()
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundTransparency=0}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundTransparency=0.1}):Play()
        end)
        btn.MouseButton1Click:Connect(function() cb(btn) end)
        return btn
    end

    -- ── UNWALK ───────────────────────────────────────────────
    local unwalkOn = false
    createMvBtn("UNWALK", false, function(b)
        unwalkOn = not unwalkOn
        b.BackgroundColor3 = unwalkOn and Theme.Accent1 or Theme.Surface
        b.TextColor3 = unwalkOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        b.Text = "UNWALK " .. (unwalkOn and "(ON)" or "(OFF)")
        if _G._actToggleUnwalk then pcall(_G._actToggleUnwalk, unwalkOn) end
        ShowNotification("UNWALK", unwalkOn and "ON" or "OFF")
    end)

    -- ── FLOAT: left-click = toggle, right-click = set keybind ──
    -- Texto: "FLOAT (ON)" ou "FLOAT (OFF)" ou "FLOAT (ON) (F)" se tiver key
    local floatOn = Config.FloatEnabled or false

    local function getFloatBtnText()
        local state = floatOn and "(ON)" or "(OFF)"
        local key   = Config.FloatKey and Config.FloatKey ~= "" and Config.FloatKey or nil
        if key then
            return "FLOAT " .. state .. " (" .. key .. ")"
        else
            return "FLOAT " .. state
        end
    end

    -- Cria o botão manualmente (não via createMvBtn) para suportar right-click
    local floatBtnFrame = Instance.new("Frame", mvList)
    floatBtnFrame.Size = UDim2.new(1,-16*SCALE,0,BTN_H)
    floatBtnFrame.BackgroundTransparency = 1
    local floatBtn = Instance.new("TextButton", floatBtnFrame)
    floatBtn.Size = UDim2.new(1,0,1,0)
    floatBtn.BackgroundColor3 = floatOn and Theme.Accent1 or Theme.Surface
    floatBtn.BackgroundTransparency = 0.1
    floatBtn.Text = getFloatBtnText()
    floatBtn.Font = Enum.Font.GothamBold; floatBtn.TextSize = 12*SCALE
    floatBtn.TextColor3 = floatOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
    floatBtn.AutoButtonColor = false
    Instance.new("UICorner", floatBtn).CornerRadius = UDim.new(0,8)
    local floatBtnS = Instance.new("UIStroke", floatBtn)
    floatBtnS.Color = Theme.Accent2; floatBtnS.Thickness = 1; floatBtnS.Transparency = 0.5
    floatBtn.MouseEnter:Connect(function()
        TweenService:Create(floatBtn,TweenInfo.new(0.15),{BackgroundTransparency=0}):Play()
    end)
    floatBtn.MouseLeave:Connect(function()
        TweenService:Create(floatBtn,TweenInfo.new(0.15),{BackgroundTransparency=0.1}):Play()
    end)
    -- Left click = toggle
    floatBtn.MouseButton1Click:Connect(function()
        floatOn = not floatOn
        floatBtn.BackgroundColor3 = floatOn and Theme.Accent1 or Theme.Surface
        floatBtn.TextColor3 = floatOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        floatBtn.Text = getFloatBtnText()
        if _G.setFloat then pcall(_G.setFloat, floatOn) end
        ShowNotification("FLOAT", floatOn and "ON" or "OFF")
    end)
    -- Right click = set keybind
    floatBtn.MouseButton2Click:Connect(function()
        listenForFloatKey(floatBtn)
    end)
    -- Sync text + color (key and float state may change externally)
    task.spawn(function()
        while floatBtn and floatBtn.Parent do
            task.wait(0.2)
            if not listeningMv then
                -- Sync floatOn with actual state from _G
                if _G._floatIsOn ~= nil and _G._floatIsOn ~= floatOn then
                    floatOn = _G._floatIsOn
                    floatBtn.BackgroundColor3 = floatOn and Theme.Accent1 or Theme.Surface
                    floatBtn.TextColor3 = floatOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
                end
                -- Sync text
                local expected = getFloatBtnText()
                if floatBtn.Text ~= expected then floatBtn.Text = expected end
            end
        end
    end)

    -- ── INFINITE JUMP ────────────────────────────────────────
    local ijOn = State.infiniteJumpEnabled or false
    createMvBtn("INFINITE JUMP", ijOn, function(b)
        ijOn = not ijOn
        b.BackgroundColor3 = ijOn and Theme.Accent1 or Theme.Surface
        b.TextColor3 = ijOn and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        b.Text = "INFINITE JUMP " .. (ijOn and "(ON)" or "(OFF)")
        setInfiniteJump(ijOn)
        ShowNotification("INFINITE JUMP", ijOn and "ON" or "OFF")
    end)

    -- Auto-resize frame to fit content
    mvLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        mvFrame.Size = UDim2.new(0, W, 0, 55*SCALE + 8*SCALE + mvLayout.AbsoluteContentSize.Y + PADDING)
    end)
end)
