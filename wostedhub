    if processed then return end
    
    local tpKey = (Config.TpSettings.TpKey ~= "" and Enum.KeyCode[Config.TpSettings.TpKey]) or Enum.KeyCode.T
    local cloneKey = (Config.TpSettings.CloneKey ~= "" and Enum.KeyCode[Config.TpSettings.CloneKey]) or Enum.KeyCode.V

    if input.KeyCode == tpKey then
        -- Se o alvo selecionado for CARPET, tp direto para a esteira sem check automático
        local sel = SharedState.SelectedPetData
        if sel and sel.isConveyor then
            tpToConveyor()
        else
            -- Passa skipConveyorCheck=true se o usuário selecionou manualmente
            -- (todos os modos de steal desativados = seleção manual)
            local manualSel = (not stealHighestEnabled) and (not stealNearestEnabled) and (not stealPriorityEnabled)
            runAutoSnipe(manualSel)
        end
    end

    if input.KeyCode == cloneKey then
        instantClone()
    end
    
    if input.KeyCode == ((Config.TpSettings.CarpetSpeedKey ~= "" and Enum.KeyCode[Config.TpSettings.CarpetSpeedKey]) or Enum.KeyCode.Q) then
        carpetSpeedEnabled = not carpetSpeedEnabled
        setCarpetSpeed(carpetSpeedEnabled)
