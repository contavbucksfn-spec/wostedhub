                    best = {
                        name=entry.name or "Brainrot", mutation=mut, gv=gv,
                        gvText="$"..NumUtils2:ToString(gv).."/s",
                        plotName=nil, isCarpet=true, ownerName=nil,
                    }
                end
            end
        end

        return best
    end

    -- (convList fallback already handled above)


