    hudFrame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = inp.Position
            startPos = Vector2.new(hudFrame.AbsolutePosition.X, hudFrame.AbsolutePosition.Y)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
            local d = inp.Position - dragStart
            local vp = workspace.CurrentCamera.ViewportSize
            local newX = math.clamp(startPos.X + d.X, 0, vp.X - hudFrame.AbsoluteSize.X)
            local newY = math.clamp(startPos.Y + d.Y, 0, vp.Y - hudFrame.AbsoluteSize.Y)
            hudFrame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                Config.Positions = Config.Positions or {}
                local vp = workspace.CurrentCamera.ViewportSize
                Config.Positions["UnlockHUD"] = {
                    X = hudFrame.AbsolutePosition.X / vp.X,
                    Y = hudFrame.AbsolutePosition.Y / vp.Y,
                }
                SaveConfig()
            end
        end
    end)

    -- Botão inverter (🔄) — sempre visível à esquerda
    local invertBtn = Instance.new("TextButton", hudFrame)
    invertBtn.Size = UDim2.new(0, TOGGLE, 0, H)
    invertBtn.Position = UDim2.new(0, 0, 0, 0)
    invertBtn.BackgroundColor3 = Color3.fromRGB(220, 160, 20)
    invertBtn.BackgroundTransparency = 0
    invertBtn.Text = "🔄"
    invertBtn.Font = Enum.Font.GothamBlack
    invertBtn.TextSize = 22
    invertBtn.TextColor3 = Color3.fromRGB(255,255,255)
    invertBtn.BorderSizePixel = 0
    Instance.new("UICorner", invertBtn).CornerRadius = UDim.new(0, 14)

    -- 3 botões de unlock
    local unlockLevels = {-2, 15, 32}
    local unlockBtns = {}
    for i = 1, 3 do
        local btn = Instance.new("TextButton", hudFrame)
        btn.Size = UDim2.new(0, BTN, 0, H)
        btn.Position = UDim2.new(0, TOGGLE + GAP + (i-1)*(BTN+GAP), 0, 0)
        btn.BackgroundColor3 = Color3.fromRGB(25, 30, 50)
        btn.BackgroundTransparency = 0
        btn.Text = tostring(i)
        btn.Font = Enum.Font.GothamBlack
        btn.TextSize = 20
        btn.TextColor3 = Color3.fromRGB(80, 200, 255)
        btn.BorderSizePixel = 0
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 14)
        local bs = Instance.new("UIStroke", btn)
        bs.Color = Color3.fromRGB(70, 130, 230)
        bs.Thickness = 1.5
        bs.Transparency = 0.35

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(40,55,90)}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(25,30,50)}):Play()
        end)
        btn.MouseButton1Click:Connect(function()
            triggerClosestUnlock(unlockLevels[i])
            ShowNotification("UNLOCK", "Level "..i)
        end)
        unlockBtns[i] = btn
    end

    -- Inverter: alterna entre layout HORIZONTAL (1 2 3 lado a lado) e VERTICAL (1 acima 2 acima 3)
    local isVertical = false

    local function applyLayout()
        if isVertical then
            -- Layout vertical: emote no topo, 1/2/3 empilhados abaixo
            local W_V = math.max(TOGGLE, BTN)
            local VERT_H = TOGGLE + GAP + 3*BTN + 2*GAP
            hudFrame.Size = UDim2.new(0, W_V, 0, VERT_H)
            invertBtn.Size = UDim2.new(0, W_V, 0, TOGGLE)
            invertBtn.Position = UDim2.new(0, 0, 0, 0)
            for i, b in ipairs(unlockBtns) do
                b.Size = UDim2.new(0, W_V, 0, BTN)
                b.Position = UDim2.new(0, 0, 0, TOGGLE + GAP + (i-1)*(BTN+GAP))
            end
        else
            -- Layout horizontal: emote à esquerda, 1/2/3 ao lado
            hudFrame.Size = UDim2.new(0, TOTAL_W, 0, H)
            invertBtn.Size = UDim2.new(0, TOGGLE, 0, H)
            invertBtn.Position = UDim2.new(0, 0, 0, 0)
            for i, b in ipairs(unlockBtns) do
                b.Size = UDim2.new(0, BTN, 0, H)
                b.Position = UDim2.new(0, TOGGLE + GAP + (i-1)*(BTN+GAP), 0, 0)
            end
        end
    end

    invertBtn.MouseButton1Click:Connect(function()
        isVertical = not isVertical
        applyLayout()
        -- Re-save position after layout change
        local vp = workspace.CurrentCamera.ViewportSize
        Config.Positions = Config.Positions or {}
        Config.Positions["UnlockHUD"] = {
            X = hudFrame.AbsolutePosition.X / vp.X,
            Y = hudFrame.AbsolutePosition.Y / vp.Y,
        }
        SaveConfig()
    end)

    _G._setUnlockHUDVisible = function(v)
        unlockGui.Enabled = v
    end
end)

