task.spawn(function()
    while true do
        task.wait(2)
        if not Config.AutoBackToBrainrot then continue end
        if LocalPlayer:GetAttribute("Stealing") then continue end
        local cache = SharedState.AllAnimalsCache
        if not cache or #cache == 0 then continue end
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        -- Find best target
        local target = nil
        for _,pN in ipairs(PRIORITY_LIST) do
            for _,a in ipairs(cache) do
                if a and a.name and a.name:lower()==pN:lower() and a.owner~=LocalPlayer.Name then
                    target=a; break
                end
            end
            if target then break end
        end
        if not target then
            for _,a in ipairs(cache) do
                if a and a.owner~=LocalPlayer.Name then target=a; break end
            end
        end
        if not target then continue end
        -- Não interfere com TPs em andamento nem logo após um TP (cooldown 8s)
        if State.isTpMoving then continue end
        if _G._lastAnyTpTime and (tick() - _G._lastAnyTpTime) < 8 then continue end
