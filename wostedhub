local function setFOVBypass(val)
    val = math.clamp(val, FOV_MIN, FOV_MAX)
    local cam = Workspace.CurrentCamera
    if not cam then return end
    -- Tenta remover o cap de 120 via sethiddenproperty (executors)
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(cam, "MaxFieldOfView", val)
        end
    end)
    -- Tenta também via gethiddenproperty + set direto
    pcall(function() cam.FieldOfView = val end)
    -- Força com pequeno delay para garantir
    task.defer(function()
        pcall(function() cam.FieldOfView = val end)
    end)
end
local function updateFOVSlider(val)
    val = math.clamp(math.floor(val + 0.5), FOV_MIN, FOV_MAX)
    Config.FOV = val; SaveConfig()
    fovValLbl.Text = tostring(val)
    local pct = (val - FOV_MIN) / (FOV_MAX - FOV_MIN)
    fovFill.Size = UDim2.new(pct, 0, 1, 0)
    fovKnob.Position = UDim2.new(pct, 0, 0.5, 0)
    setFOVBypass(val)
end
