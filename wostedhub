            local sName = pName:lower()
            for _, c in ipairs(candidates) do
                if c.name and c.name:lower() == sName then
                    best = c; break
                end
            end
            if best then break end
        end
        -- Se não achou nada na priority list, usa o de maior GV
        if not best then
            local bestGv = -1
            for _, c in ipairs(candidates) do
                if c.gv > bestGv then bestGv = c.gv; best = c end
            end
        end

        -- Verifica esteira — só substitui se gv da esteira > melhor encontrado
        local bestGv2 = best and best.gv or -1
        local convList = SharedState.ConveyorAnimals
        if convList then
            for _, entry in ipairs(convList) do
                local gv = tonumber(entry.gv) or 0
                local valid = (entry.part and entry.part.Parent) or (entry.prompt and entry.prompt.Parent)
                if valid and gv > bestGv2 then
