task.spawn(function()
    _G.AutoBuyEsteira = true

    -- Clean up old UI if exists
    local _oldAB = PlayerGui:FindFirstChild("WostedAutoBuyUI")
    if _oldAB then _oldAB:Destroy() end

    -- BACKEND: compra automaticamente quando próximo do brainrot mais caro do CARPET
    -- SEM gruda/hover - apenas compra quando o player chegar por conta própria
    task.spawn(function()
        local BUY_INTERVAL  = 0.1
        local DETECT_RADIUS = 15
        local lastBuy       = 0

        local function firePurchase(prompt)
            if not prompt or not prompt.Parent or not prompt.Enabled then return end
            pcall(function()
                if fireproximityprompt then fireproximityprompt(prompt) end
            end)
        end

        -- Encontra o brainrot MAIS CARO do CARPET inteiro (não apenas em range)
        local function getBestConveyorEntry()
            local best, bestGv = nil, -1
            for _, entry in ipairs(SharedState.ConveyorAnimals or {}) do
                if entry.prompt and entry.prompt.Parent and entry.prompt.Enabled
                and entry.part  and entry.part.Parent then
                    local gv = tonumber(entry.gv) or 0
                    if gv > bestGv then bestGv = gv; best = entry end
                end
            end
            return best
        end

        RunService.Heartbeat:Connect(function()
            local now = tick()
            if now - lastBuy < BUY_INTERVAL then return end

            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            -- Pega o brainrot mais caro do CARPET
            local best = getBestConveyorEntry()
            if not best then return end

            -- Só compra se o player já está próximo (sem forçar movimento)
            local dist = (hrp.Position - best.part.Position).Magnitude
            local radius = Config.AutoBuyRange or DETECT_RADIUS
            if dist > radius then return end

            -- Compra!
            lastBuy = now
            firePurchase(best.prompt)
        end)
    end)
end)

