                    owner=a.owner, plot=a.plot, slot=a.slot, uid=a.uid, mutation=a.mutation, animalData=a})
            end
        end

        -- Adiciona CARPET na posição correta por gv (não forçado no topo)
        local convList = SharedState.ConveyorAnimals
        if convList and #convList > 0 then
            local bestConv, bestConvGv = nil, -1
            for _, entry in ipairs(convList) do
