    -- ══════════════════════════════════════════════════════════
    -- TRACE BRAINROT BEAM
    -- ══════════════════════════════════════════════════════════
    do
        local brainrotBeamFolder = Instance.new("Folder", Workspace)
        brainrotBeamFolder.Name = "WostedBrainrotTracers"
        local bBeam = nil
        local bAtt0 = nil
        local bAtt1 = nil

        -- Retorna {animalData=..., part=..., isConveyor=bool}
        local function getBrainrotTraceTarget()
            local pets = get_all_pets()
            local isNearest   = _G._stealModeNearest  or false
            local isPriorityM = _G._stealModePriority or false

            -- Função auxiliar: retorna part do alvo (base ou carpet)
            local function toPart(p)
                if p.isConveyor then
                    return p.conveyorEntry and p.conveyorEntry.part
                end
                return p.animalData and findAdorneeGlobal(p.animalData)
            end

            if isPriorityM then
                -- PRIORITY: primeiro pet da lista de prioridade
                -- CARPET nunca entra em priority (não é base)
                for _, pName in ipairs(PRIORITY_LIST) do
                    for _, p in ipairs(pets) do
                        if not p.isConveyor and p.petName and p.petName:lower() == pName:lower() then
                            return {part = toPart(p), isConveyor = false, mutation = p.mutation}
                        end
                    end
                end
                -- Se não achou na lista, pega o primeiro (pode ser carpet)
                local p = pets[1]
                if p then return {part = toPart(p), isConveyor = p.isConveyor, mutation = p.mutation} end
                return nil

            elseif isNearest then
                -- NEAREST: o mais próximo do player (incluindo carpet)
                local char = LocalPlayer.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then
                    local p = pets[1]
                    return p and {part = toPart(p), isConveyor = p.isConveyor, mutation = p.mutation}
                end
                local best, bestDist = nil, math.huge
                for _, p in ipairs(pets) do
                    local pt = toPart(p)
                    if pt and pt.Parent then
                        local d = (hrp.Position - pt.Position).Magnitude
                        if d < bestDist then
                            bestDist = d
                            best = {part = pt, isConveyor = p.isConveyor, mutation = p.mutation}
                        end
                    end
                end
                return best

            else
                -- HIGHEST: pega o de maior mpsValue (pets já ordenados, index 1 = maior)
                -- Mas compara também com carpet
                local p = pets[1]
                if p then return {part = toPart(p), isConveyor = p.isConveyor, mutation = p.mutation} end
                return nil
            end
        end

        local MUT_COLORS_TRACE = {
            Normal=Color3.fromRGB(180,180,180), Cursed=Color3.fromRGB(200,0,0),
            Gold=Color3.fromRGB(255,215,0), Diamond=Color3.fromRGB(0,255,255),
            YinYang=Color3.fromRGB(220,220,220), Rainbow=Color3.fromRGB(255,100,200),
            Lava=Color3.fromRGB(255,100,20), Candy=Color3.fromRGB(255,105,180),
            Divine=Color3.fromRGB(255,255,255), Galaxy=Color3.fromRGB(180,80,255),
            Radioactive=Color3.fromRGB(80,255,80), Bloodrot=Color3.fromRGB(140,0,0),
        }

        RunService.Heartbeat:Connect(function()
            if not Config.TraceBrainrot then
                if bBeam then bBeam.Enabled = false end
                return
            end
            local traceResult = getBrainrotTraceTarget()
            local targetPart  = traceResult and traceResult.part
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")

            if hrp and targetPart and targetPart.Parent then
                if not bAtt0 or bAtt0.Parent ~= hrp then
                    if bAtt0 then bAtt0:Destroy() end
                    bAtt0 = Instance.new("Attachment", hrp)
                end
                if not bAtt1 or bAtt1.Parent ~= targetPart then
                    if bAtt1 then bAtt1:Destroy() end
                    bAtt1 = Instance.new("Attachment", targetPart)
                end
                if not bBeam then
                    bBeam = Instance.new("Beam", brainrotBeamFolder)
                    bBeam.FaceCamera = true
                    bBeam.Width0 = 0.8; bBeam.Width1 = 0.8
                    bBeam.TextureMode = Enum.TextureMode.Static
                    bBeam.TextureSpeed = 3
                    bBeam.LightEmission = 1
                end
                bBeam.Attachment0 = bAtt0
                bBeam.Attachment1 = bAtt1
                bBeam.Enabled = true
                -- Cor pela mutação; carpet = roxo claro
                local mut = traceResult.mutation
                local col
                if traceResult.isConveyor then
                    col = Color3.fromRGB(200,160,255) -- roxo carpet
                else
                    col = MUT_COLORS_TRACE[mut] or Color3.fromRGB(255,60,60)
                end
                bBeam.Color = ColorSequence.new(col)
            else
                if bBeam then bBeam.Enabled = false end
            end
        end)

        _G.resetBrainrotBeam = function()
            if bBeam then pcall(function() bBeam:Destroy() end); bBeam = nil end
            if bAtt0 then pcall(function() bAtt0:Destroy() end); bAtt0 = nil end
            if bAtt1 then pcall(function() bAtt1:Destroy() end); bAtt1 = nil end
        end
        _G.updateBrainrotBeam = function() end -- compatibility
    end

