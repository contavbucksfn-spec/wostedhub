        local function refreshBrainrotESP()
            if _G._brainrotESPEnabled == false then return end
            local cache = allAnimalsCache
            if not cache or #cache == 0 then return end

            local seen = {}
            for _, data in ipairs(cache) do
                -- Only show priority brainrots
                if data.uid and data.owner ~= LocalPlayer.Name and isPriority(data.name) then
                    seen[data.uid] = true
                    if not brainrotBillboards[data.uid] then
                        local adornee = nil
                        local overhead = nil
                        local studsOffset = Vector3.new(0, 1.8, 0)

                        if data.plot and data.slot then
                            adornee = findAdorneeGlobal(data)
                            if adornee then
                                local model = adornee.Parent
                                if model and model:IsA("Model") then
                                    for _, child in ipairs(model:GetDescendants()) do
                                        if child.Name == "AnimalOverhead" and child:IsA("BillboardGui") then
                                            overhead = child
                                            break
                                        end
                                    end
                                    if overhead then
                                        studsOffset = overhead.StudsOffset
                                        hideDefaultOverhead(overhead)
                                    end
                                end
                            end
                        end

                        if adornee then
                            local bb, nameLabel = createBrainrotBillboard(data)
                            bb.Adornee = adornee
                            bb.StudsOffset = studsOffset
                            bb.Parent = adornee
                            brainrotBillboards[data.uid] = {bb=bb, nameLabel=nameLabel, overhead=overhead, mut=data.mutation}
                        end
                    end
                end
            end

            for uid, entry in pairs(brainrotBillboards) do
                if not seen[uid] then
                    pcall(function() if entry.bb then entry.bb:Destroy() end end)
                    if entry.overhead then showDefaultOverhead(entry.overhead) end
                    brainrotBillboards[uid] = nil
                end
            end
        end

        local function clearBrainrotESP()
            for _, entry in pairs(brainrotBillboards) do
                pcall(function() if entry.bb then entry.bb:Destroy() end end)
                if entry.overhead then showDefaultOverhead(entry.overhead) end
            end
            brainrotBillboards = {}
            restoreAllOverheads()
        end

        -- CONVEYOR ESP: shows only the BEST (highest gv) conveyor brainrot
        -- No background, no outline — only name + gen/s (integrated with Brainrot ESP toggle)
        local currentConvBB = nil

        local function refreshConveyorESP()
            -- Clean old billboard
            if currentConvBB and currentConvBB.Parent then
                currentConvBB:Destroy()
                currentConvBB = nil
            end
            if not brainrotESPEnabled or _G._brainrotESPEnabled == false then return end
            local convList = SharedState.ConveyorAnimals
            if not convList or #convList == 0 then return end

            -- Find the best (highest gv)
            local best, bestGv = nil, -1
            for _, entry in ipairs(convList) do
                local gv = tonumber(entry.gv) or 0
                if entry.part and entry.part.Parent and gv > bestGv then
                    bestGv = gv
                    best = entry
                end
            end
            if not best then return end

            -- Pega a cor da mutação igual ao Brainrot ESP (Normal = cinza)
            local convMut = best.mutation or "Normal"
            local convColor = getMutColor(convMut)

            local bb = Instance.new("BillboardGui")
            bb.Name = "WostedConvESP_Best"
            bb.Size = UDim2.new(0, 220, 0, 50)
            bb.StudsOffset = Vector3.new(0, 4, 0)
            bb.AlwaysOnTop = true
            bb.LightInfluence = 0
            bb.MaxDistance = 500
            bb.Adornee = best.part
            bb.Parent = best.part

            local nameL = Instance.new("TextLabel", bb)
            nameL.Size = UDim2.new(1,0,0,28)
            nameL.Position = UDim2.new(0,0,0,0)
            nameL.BackgroundTransparency = 1
            nameL.Font = Enum.Font.GothamBlack
            nameL.TextSize = 18
            nameL.RichText = true
            nameL.TextStrokeTransparency = 0.2
            nameL.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            nameL.TextXAlignment = Enum.TextXAlignment.Center
            -- Cor igual ao Brainrot ESP por mutação
            if convMut == "Rainbow" then
                nameL.Text = makeRainbowText(tostring(best.name or "Brainrot"), 0)
            elseif convMut == "YinYang" then
                nameL.Text = makeYYText(tostring(best.name or "Brainrot"))
            else
                nameL.TextColor3 = convColor
                nameL.Text = tostring(best.name or "Brainrot")
            end

            local genL = Instance.new("TextLabel", bb)
            genL.Size = UDim2.new(1,0,0,22)
            genL.Position = UDim2.new(0,0,0,28)
            genL.BackgroundTransparency = 1
            genL.Font = Enum.Font.GothamBold
            genL.TextSize = 14
            genL.TextColor3 = Color3.fromRGB(200,255,180)
            genL.TextStrokeTransparency = 0.2
            genL.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            genL.Text = tostring(best.gen or "")
            genL.TextXAlignment = Enum.TextXAlignment.Center

            currentConvBB = bb
        end

        task.spawn(function()
            while true do
                task.wait(0.5)
                pcall(refreshConveyorESP)
            end
        end)
        _G._refreshConveyorESP = refreshConveyorESP

        -- Animação Rainbow: rotaciona cores a cada 0.18s
        task.spawn(function()
            local offset = 0
            while true do
                task.wait(0.18)
                offset = (offset + 1) % #RAINBOW_COLS
                for uid, entry in pairs(brainrotBillboards) do
                    if entry.mut == "Rainbow" and entry.nameLabel and entry.bb and entry.bb.Parent then
                        for _, data in ipairs(allAnimalsCache) do
                            if data.uid == uid then
                                entry.nameLabel.Text = makeRainbowText(data.name or "???", offset)
                                break
                            end
                        end
                    end
                end
            end
        end)

        -- Refresh ESP a cada 0.3s
        task.spawn(function()
            while true do
                task.wait(0.3)
                if brainrotESPEnabled and _G._brainrotESPEnabled ~= false then pcall(refreshBrainrotESP) end
            end
        end)

        -- Re-scan a cada 2s para garantir que nada perdeu
        task.spawn(function()
            while true do
                task.wait(2)
                if brainrotESPEnabled and _G._brainrotESPEnabled ~= false then pcall(refreshBrainrotESP) end
            end
        end)

        _G._brainrotESPEnabled = brainrotESPEnabled
        _G._clearBrainrotESP   = clearBrainrotESP
        _G._refreshBrainrotESP = refreshBrainrotESP
    end

end)


