    -- BRAINROT WORLD ESP (Priority only + Conveyor)
    -- ══════════════════════════════════════════════════════════
    do
        local brainrotBillboards = {}
        local conveyorBillboards = {}
        local hiddenOverheads    = {}
        local brainrotESPEnabled = true
        _G._brainrotESPEnabled = true

        local MUT_COLORS = {
            Normal      = Color3.fromRGB(180, 180, 180),
            Gold        = Color3.fromRGB(255, 215, 0),
            Diamond     = Color3.fromRGB(70,  180, 255),
            Divine      = Color3.fromRGB(255, 215, 0),
            Lava        = Color3.fromRGB(255, 140, 30),
            Candy       = Color3.fromRGB(255, 105, 180),
            Bloodrot    = Color3.fromRGB(140, 0,   0),
            Radioactive = Color3.fromRGB(80,  255, 80),
            YinYang     = Color3.fromRGB(220, 220, 220),
            Galaxy      = Color3.fromRGB(180, 80,  255),
            Cursed      = Color3.fromRGB(220, 30,  30),
            Rainbow     = Color3.fromRGB(255, 80,  200),
        }
        local RAINBOW_COLS = {
            Color3.fromRGB(255,60,60), Color3.fromRGB(255,160,30),
            Color3.fromRGB(255,240,0), Color3.fromRGB(60,220,60),
            Color3.fromRGB(60,120,255), Color3.fromRGB(148,0,211),
        }

        local function getMutColor(mut)
            if not mut or mut == "None" then return Color3.fromRGB(180,180,180) end
            return MUT_COLORS[mut] or Color3.fromRGB(200,100,255)
        end

        local function richColor(c, text)
            return string.format("<font color='rgb(%d,%d,%d)'>%s</font>",
                math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255), text)
        end

        local function makeRainbowText(str, offset)
            local out = ""; local ci = (offset or 0) + 1
            for i = 1, #str do
                local ch = str:sub(i,i)
                if ch == " " then out = out.." "
                else
                    local c = RAINBOW_COLS[ci]
                    out = out..richColor(c, ch)
                    ci = ci % #RAINBOW_COLS + 1
                end
            end
            return out
        end

        local function makeYYText(str)
            local out = ""; local flip = true
            for i = 1, #str do
                local ch = str:sub(i,i)
                if ch == " " then out = out.." "
                elseif flip then out = out.."<font color='rgb(255,255,255)'>"..ch.."</font>"; flip = false
                else out = out.."<font color='rgb(40,40,40)'>"..ch.."</font>"; flip = true end
            end
            return out
        end

        local function createBrainrotBillboard(data)
            local hasMut = data.mutation and data.mutation ~= "None" and data.mutation ~= "N/A"
            local color  = getMutColor(data.mutation or "Normal")

            local bb = Instance.new("BillboardGui")
            bb.Name = "WostedBrainrotESP_" .. data.uid
            bb.Size = UDim2.new(0, 200, 0, 44)
            bb.StudsOffset = Vector3.new(0, 1.8, 0)
            bb.AlwaysOnTop = true
            bb.LightInfluence = 0
            bb.MaxDistance = 3000

            -- Sem fundo nem outline — só texto puro com sombra
            local nameLabel = Instance.new("TextLabel", bb)
            nameLabel.Size = UDim2.new(1,0,0,26)
            nameLabel.Position = UDim2.new(0,0,0,0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Font = Enum.Font.GothamBlack
            nameLabel.TextSize = 16
            nameLabel.RichText = true
            nameLabel.TextStrokeTransparency = 0.2
            nameLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            nameLabel.TextXAlignment = Enum.TextXAlignment.Center

            local genLabel = Instance.new("TextLabel", bb)
            genLabel.Size = UDim2.new(1,0,0,18)
            genLabel.Position = UDim2.new(0,0,0,26)
            genLabel.BackgroundTransparency = 1
            genLabel.Font = Enum.Font.GothamBold
            genLabel.TextSize = 13
            genLabel.TextColor3 = Color3.fromRGB(200,255,180)
            genLabel.TextStrokeTransparency = 0.2
            genLabel.TextStrokeColor3 = Color3.fromRGB(0,0,0)
            genLabel.Text = (data.mpsText or data.genText or "")
            genLabel.TextXAlignment = Enum.TextXAlignment.Center

            -- Texto do nome com cor da mutação
            local mut = data.mutation
            if mut == "Rainbow" then
                nameLabel.Text = makeRainbowText(data.name or "???", 0)
            elseif mut == "YinYang" then
                nameLabel.Text = makeYYText(data.name or "???")
            else
                nameLabel.TextColor3 = color
                nameLabel.Text = data.name or "???"
            end

            return bb, nameLabel
        end

        local function hideDefaultOverhead(overhead)
            if overhead and overhead.Parent and not hiddenOverheads[overhead] then
                hiddenOverheads[overhead] = overhead.Enabled
                overhead.Enabled = false
            end
        end
        local function showDefaultOverhead(overhead)
            if overhead and hiddenOverheads[overhead] ~= nil then
                overhead.Enabled = hiddenOverheads[overhead]
                hiddenOverheads[overhead] = nil
            end
        end
        local function restoreAllOverheads()
            for overhead, wasEnabled in pairs(hiddenOverheads) do
                if overhead and overhead.Parent then overhead.Enabled = wasEnabled end
            end
            hiddenOverheads = {}
        end

        -- Check if a pet is in the priority list
        local function isPriority(name)
            if not name then return false end
            local nl = name:lower()
