-- ── RAINBOW BASE ──────────────────────────────────────────────────────────
do
    local _rbRunService  = game:GetService("RunService")
    local _rbPlayerGui   = LocalPlayer:WaitForChild("PlayerGui")
    local RAINBOW_SPEED  = 0.4
    local FILL_TRANSP    = 0.8
    local OUTLINE_TRANSP = 0.0

    local _rbHolder, _rbHighlight, _rbRainbowConn, _rbGuardConn
    local _rbActive = false
    -- Expõe funções e plot para integração com X-Ray
    _G._rbSetHighlightEnabled = function(enabled)
        if _rbHighlight and _rbHighlight.Parent then
            _rbHighlight.Enabled = enabled
        end
    end
    _G._rbGetMyPlot = function()
        return _rbActive and _rbHolder and _rbHolder.Parent and _rbHighlight and _rbHighlight.Adornee or nil
    end

    local function _rbFindPlot()
        local plots = workspace:FindFirstChild("Plots")
        if not plots then return nil end
        for _, plot in ipairs(plots:GetChildren()) do
            for _, desc in ipairs(plot:GetDescendants()) do
                if desc:IsA("TextLabel") then
                    local t = desc.Text:lower()
                    if t:find(LocalPlayer.Name:lower(), 1, true)
                    or t:find(LocalPlayer.DisplayName:lower(), 1, true) then
                        return plot
                    end
                end
            end
        end
        return nil
    end

    local function _rbStart()
        if _rbActive then return end
        local myPlot = _rbFindPlot()
        if not myPlot then ShowNotification("RAINBOW BASE", "Plot não encontrada!") return end
        local pods = myPlot:FindFirstChild("AnimalPodiums")

        _rbHolder = Instance.new("ScreenGui")
        _rbHolder.Name = "RainbowBaseGui"; _rbHolder.ResetOnSpawn = false; _rbHolder.Parent = _rbPlayerGui

        _rbHighlight = Instance.new("Highlight")
        _rbHighlight.Adornee             = myPlot
        _rbHighlight.FillColor           = Color3.fromRGB(255,0,0)
        _rbHighlight.OutlineColor        = Color3.fromRGB(255,0,0)
        _rbHighlight.FillTransparency    = FILL_TRANSP
        _rbHighlight.OutlineTransparency = OUTLINE_TRANSP
        _rbHighlight.DepthMode           = Enum.HighlightDepthMode.Occluded
        _rbHighlight.Enabled             = true
        _rbHighlight.Parent              = _rbHolder

        local brainrotColors = {}
        if pods then
            for _, pod in ipairs(pods:GetDescendants()) do
                if pod:IsA("BasePart") then brainrotColors[pod] = pod.Color end
            end
        end

        -- Coleta partes da base (excluindo podiums) para forçar LTM=0
        local baseParts = {}
        for _, v in ipairs(myPlot:GetDescendants()) do
            if v:IsA("BasePart") and (not pods or not v:IsDescendantOf(pods)) then
                table.insert(baseParts, v)
            end
        end

        _rbActive = true
        _G._rbIsActive = true
        local hue = 0
        _rbRainbowConn = _rbRunService.RenderStepped:Connect(function(dt)
            hue = (hue + dt * RAINBOW_SPEED) % 1
            _G._rbCurrentHue = hue
            local color = Color3.fromHSV(hue, 1, 1)
            if _rbHighlight and _rbHighlight.Parent then
                _rbHighlight.FillColor = color; _rbHighlight.OutlineColor = color
            end
            for part, origColor in pairs(brainrotColors) do
                if part and part.Parent then part.Color = origColor end
            end
        end)

        _rbGuardConn = _rbRunService.Heartbeat:Connect(function()
            if _rbHighlight and _rbHighlight.Parent and not _rbHighlight.Enabled then
                _rbHighlight.Enabled = true
            end
            -- Força LTM=0 nas partes da base para anular o X-Ray na nossa base
            for _, v in ipairs(baseParts) do
                if v and v.Parent and v.LocalTransparencyModifier ~= 0 then
                    v.LocalTransparencyModifier = 0
                end
            end
        end)
    end

    local function _rbStop()
        if not _rbActive then return end
        _rbActive = false
        _G._rbIsActive = false
        if _rbRainbowConn then _rbRainbowConn:Disconnect() end
        if _rbGuardConn   then _rbGuardConn:Disconnect()   end
        if _rbHighlight and _rbHighlight.Parent then _rbHighlight:Destroy() end
        if _rbHolder    and _rbHolder.Parent    then _rbHolder:Destroy()    end
        _rbHighlight = nil; _rbHolder = nil

        -- Se X-Ray está ativo, reaplica APENAS na nossa base (sem tocar nas outras)
        if XrayState.xrayEnabled then
            local myPlot = _rbFindPlot()
            if myPlot then
                for _, v in ipairs(myPlot:GetDescendants()) do
                    if v:IsA("BasePart") and v.Anchored and isBaseWall(v) then
                        if XrayState.originalTransparency[v] == nil then
                            XrayState.originalTransparency[v] = v.LocalTransparencyModifier
                        end
                        v.LocalTransparencyModifier = 0.85
                    end
                end
            end
        end
    end

    local rRainbowBase = CreateRow("Base Rainbow")
    CreateToggleSwitch(rRainbowBase, Config.RainbowBase, function(ns, set)
        set(ns)
        Config.RainbowBase = ns
        SaveConfig()
        if ns then _rbStart() else _rbStop() end
        ShowNotification("RAINBOW BASE", ns and "ENABLED" or "DISABLED")
    end)
    if Config.RainbowBase then
        task.spawn(function()
            task.wait(2)
            _rbStart()
            -- Re-aplica xray pulando a base do jogador
            if Config.XrayEnabled then
                enableXray()
            end
        end)
    end
end
