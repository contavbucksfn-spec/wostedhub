local Decrypted
Decrypted = setmetatable({}, {
    __index = function(S, ez)
        -- Busca segura pelas pastas
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local Packages = ReplicatedStorage:FindFirstChild("Packages")
        local Netty = Packages and Packages:FindFirstChild("Net")

        -- Se a pasta de rede (Net) não existir, para aqui e não dá erro
        if not Netty then 
            return nil 
        end

        local prefix, path
        if ez:sub(1,3) == "RE/" then 
            prefix = "RE/"; path = ez:sub(4)
        elseif ez:sub(1,3) == "RF/" then 
            prefix = "RF/"; path = ez:sub(4)
        else 
            return nil 
        end

        local Remote
        -- Tenta pegar os filhos com proteção contra erro de indexação nil
        local success, children = pcall(function() return Netty:GetChildren() end)
        
        if success and children then
            for i, v in ipairs(children) do
                if v.Name == ez then
                    -- Pega o próximo objeto da lista (o Remote real)
                    Remote = children[i + 1]
                    break
                end
            end
        end
        
        if Remote and not rawget(Decrypted, ez) then 
            rawset(Decrypted, ez, Remote) 
        end
        return rawget(Decrypted, ez)
    end
})
