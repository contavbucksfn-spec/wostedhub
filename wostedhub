                end
            end
            if bestConv and bestConvGv >= 1 then
                local carpetUid = "carpet_" .. (bestConv.name or "?") .. "_" .. tostring(math.floor(bestConvGv))
                local carpetEntry = {
                    petName  = (bestConv.name or "Brainrot"),
                    mpsText  = fmtGv(bestConvGv),
                    mpsValue = bestConvGv,
                    owner    = "CARPET",
                    plot     = nil, slot = nil,
                    uid      = carpetUid,
                    mutation = bestConv.mutation or "Normal",
                    animalData = nil,
                    isConveyor = true,
                    conveyorEntry = bestConv,
                }
                -- Insere na posição correta (ordenado por gv desc)
                local inserted = false
                for i, p in ipairs(out) do
                    if bestConvGv > p.mpsValue then
                        table.insert(out, i, carpetEntry)
                        inserted = true
                        break
                    end
                end
                if not inserted then
                    table.insert(out, carpetEntry)
                end
            end
        end

        -- Quando stealPriorityEnabled, reordena por lista de prioridade
        -- (carpet não entra na prioridade — fica na posição de gv)
        if stealPriorityEnabled then
            local prioritized = {}
            local remaining = {}
            local carpetEntries = {}
            -- Separa carpets
            for _, p in ipairs(out) do
                if p.isConveyor then table.insert(carpetEntries, p)
                else table.insert(remaining, p) end
            end
            -- Adiciona em ordem de prioridade
            local used = {}
            for _, pName in ipairs(PRIORITY_LIST) do
                local searchName = pName:lower()
                for idx, p in ipairs(remaining) do
                    if not used[idx] and p.petName and p.petName:lower() == searchName then
                        table.insert(prioritized, p)
                        used[idx] = true
                        break
                    end
                end
            end
            -- Adiciona os que não estão na lista (por gv)
            for idx, p in ipairs(remaining) do
                if not used[idx] then table.insert(prioritized, p) end
            end
            -- Reinsere carpets na posição de gv
            for _, ce in ipairs(carpetEntries) do
                local inserted = false
                for i, p in ipairs(prioritized) do
                    if ce.mpsValue > p.mpsValue then
                        table.insert(prioritized, i, ce); inserted = true; break
                    end
                end
                if not inserted then table.insert(prioritized, ce) end
