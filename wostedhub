                        return
                    end
                    local hDist = (Vector2.new(hrp.Position.X,hrp.Position.Z)-Vector2.new(tp.Position.X,tp.Position.Z)).Magnitude
                    if hDist > 40 then
                        if not State.isTpMoving and not LocalPlayer:GetAttribute("Stealing")
