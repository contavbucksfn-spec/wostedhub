                            if _G._actRunAutoSnipe then pcall(_G._actRunAutoSnipe) end
                        end
                        return
                    end
                    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z)
                    hrp.CFrame = CFrame.new(tp.Position)
                end)
            end
            lastH = newH
        end)
