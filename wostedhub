        Diamond=Color3.fromRGB(70,180,255), Divine=Color3.fromRGB(255,215,0),
        Lava=Color3.fromRGB(255,140,30), Candy=Color3.fromRGB(255,105,180),
        Bloodrot=Color3.fromRGB(140,0,0), Radioactive=Color3.fromRGB(80,255,80),
        YinYang=Color3.fromRGB(220,220,220), Galaxy=Color3.fromRGB(180,80,255),
        Cursed=Color3.fromRGB(220,30,30), Rainbow=Color3.fromRGB(255,80,200),
    }
    local RAINBOW2 = {
        Color3.fromRGB(255,60,60), Color3.fromRGB(255,160,30),
        Color3.fromRGB(255,240,0), Color3.fromRGB(60,220,60),
        Color3.fromRGB(60,120,255), Color3.fromRGB(148,0,211),
    }
    local function getMC2(mut)
        if not mut or mut=="None" or mut=="Normal" then return Color3.fromRGB(180,180,180) end
        return MUT_COL2[mut] or Color3.fromRGB(200,100,255)
    end
    local function richC2(c,t)
        return string.format("<font color='rgb(%d,%d,%d)'>%s</font>",
            math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255),t)
    end
    local function rainbowName(name)
        local out=""; local ci=1
        for i=1,#name do
            local ch=name:sub(i,i)
            if ch==" " then out=out.." "
            else out=out..richC2(RAINBOW2[ci],ch); ci=ci%#RAINBOW2+1 end
        end
        return out
    end
    local function formatMutName(mut,name)
        if not mut or mut=="None" or mut=="Normal" then
            return "<font weight='800'>"..name.."</font>"
        end
        if mut=="Rainbow" then return "<font weight='800'>"..rainbowName(name).."</font>" end
        local c=getMC2(mut)
        return richC2(c,"<font weight='800'>"..name.."</font>")
    end
    local function formatMutLabel(mut)
        if not mut or mut=="None" or mut=="Normal" then return "" end
        if mut=="Rainbow" then return "<font weight='800'>"..rainbowName(mut).."</font>" end
        if mut=="YinYang" then
            return "<font weight='800'><font color='rgb(255,255,255)'>Yin</font><font color='rgb(60,60,60)'>Yang</font></font>"
