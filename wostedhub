local function parseMinGen(str)
    if not str or type(str) ~= "string" then return 0 end
    str = str:gsub("%s", ""):lower()
    if str == "" then return 0 end
    local num, suffix = str:match("^([%d%.]+)([kmb]?)$")
    if not num then return 0 end
    num = tonumber(num)
    if not num or num < 0 then return 0 end
    if suffix == "k" then return num * 1e3
    elseif suffix == "m" then return num * 1e6
    elseif suffix == "b" then return num * 1e9
    end
    return num
end

if Config.TpSettings.TpOnLoad then
    task.spawn(function()
        local t = 0
        local player = game.Players.LocalPlayer

        -- Aguarda dados carregarem
        -- Para carpet: aguarda até ter entries com prompt válido
        local function hasValidConveyor()
            local c = SharedState.ConveyorAnimals
            if not c or #c == 0 then return false end
            for _, e in ipairs(c) do
                if e.prompt and e.prompt.Parent then return true end
            end
            return false
        end
        while (not SharedState.SelectedPetData and not hasValidConveyor())
            and t < 200 do
            task.wait(0.1)
            t = t + 1
        end
        -- Dá um tempinho extra para o scan completar
        task.wait(0.5)

        local minGen = parseMinGen(Config.TpSettings.MinGenForTp)

        if minGen > 0 then
            -- Aguarda cache
            local waitCache = 0
            while (not SharedState.AllAnimalsCache or #SharedState.AllAnimalsCache == 0) and waitCache < 100 do
                task.wait(0.1)
                waitCache = waitCache + 1
            end

            -- Helper: melhor gv de BASE excluindo próprios animais
            local function getBestEnemyBaseGv()
                local cache = SharedState.AllAnimalsCache or {}
                for _, a in ipairs(cache) do
                    if a.owner ~= LocalPlayer.Name then
                        return a.genValue or 0
                    end
                end
                return 0
            end

            -- Helper: melhor gv do CARPET
            local function getBestConvGv()
                local cl = SharedState.ConveyorAnimals or {}
                local best = -1
                for _, e in ipairs(cl) do
                    local gv = tonumber(e.gv) or 0
                    if gv > best then best = gv end
                end
                return best
            end

            -- Verifica situação inicial (excluindo próprios animais)
            local bestConvGv   = getBestConvGv()
            local bestBaseGv   = getBestEnemyBaseGv()
            local bestOverall  = math.max(bestConvGv, bestBaseGv)

            if bestOverall < minGen then
                ShowNotification("MIN GEN", "Nenhum brainrot acima de " .. (Config.TpSettings.MinGenForTp or "") .. ", aguardando...")
                -- Fica em loop esperando até ter algo acima do minGen
                while true do
                    task.wait(1)
                    local gv2 = math.max(getBestConvGv(), getBestEnemyBaseGv())
                    if gv2 >= minGen then
                        ShowNotification("AUTO TP", "Brainrot acima do mínimo encontrado!")
                        break
                    end
                end
            end
        end

        -- Verifica CARPET vs base (exclui próprios animais na comparação)
        local convList = SharedState.ConveyorAnimals or {}
        local bestConv, bestConvGv = nil, -1
        for _, e in ipairs(convList) do
            local gv = tonumber(e.gv) or 0
            local valid = (e.part and e.part.Parent) or (e.prompt and e.prompt.Parent)
            if valid and gv > bestConvGv then
                bestConvGv = gv; bestConv = e
            end
        end
        if not bestConv then
            for _, e in ipairs(convList) do
                if e.prompt and e.prompt.Parent then
                    bestConv = e; bestConvGv = tonumber(e.gv) or 0; break
                end
            end
        end

        local cache = SharedState.AllAnimalsCache or {}

        -- Melhor gv de base INIMIGA (exclui próprios animais)
        local bestBaseGv = 0
        for _, a in ipairs(cache) do
            if a.owner ~= LocalPlayer.Name then
                bestBaseGv = a.genValue or 0
                break
            end
        end

        -- minGen efetivo
        local effectiveMinGen = minGen or 0

        -- Melhor animal de base inimigo que atende minGen
        local bestBaseAnimal = nil
        for _, a in ipairs(cache) do
            if a.owner ~= LocalPlayer.Name and a.genValue >= math.max(effectiveMinGen, 1) then
                bestBaseAnimal = a
                break
            end
        end

        -- Carpet válido para minGen?
        local carpetMeetsMin = bestConv and bestConvGv >= math.max(effectiveMinGen, 1) and bestConvGv > 0

        if carpetMeetsMin and bestConvGv >= bestBaseGv then
            ShowNotification("AUTO TP", "Indo para CARPET: " .. (bestConv.name or "?"))
            tpToConveyor()
        elseif carpetMeetsMin and bestBaseGv == 0 and bestConv.prompt and bestConv.prompt.Parent then
            ShowNotification("AUTO TP", "Indo para CARPET: " .. (bestConv.name or "?"))
            tpToConveyor()
        elseif bestBaseAnimal then
            -- Força seleção do melhor animal de base inimigo que atende minGen
            SharedState.SelectedPetData = {
                petName    = bestBaseAnimal.name,
                mpsText    = bestBaseAnimal.genText,
                mpsValue   = bestBaseAnimal.genValue,
                owner      = bestBaseAnimal.owner,
                plot       = bestBaseAnimal.plot,
                slot       = bestBaseAnimal.slot,
                uid        = bestBaseAnimal.uid,
                mutation   = bestBaseAnimal.mutation,
                animalData = bestBaseAnimal,
                isConveyor = false,
            }
            runAutoSnipe(true)
        else
            -- Nenhum alvo (carpet ou base) atende o minGen → não faz TP
            ShowNotification("AUTO TP", "Nenhum alvo acima do mínimo disponível!")
        end
    end)
end


